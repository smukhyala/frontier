# ──────────────────────────────────────────────
# Frontier — Environment Variables
# Copy this file:  cp .env.example .env.local
# Then fill in every value marked <...>
# ──────────────────────────────────────────────

# Auth.js session secret — generate one with:  npx auth secret
AUTH_SECRET=<generate with: npx auth secret>

# GitHub OAuth App credentials
# Create one at https://github.com/settings/developers
#   Homepage URL:              http://localhost:3000
#   Authorization callback:    http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=<your GitHub OAuth client ID>
AUTH_GITHUB_SECRET=<your GitHub OAuth client secret>

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=<your OpenAI API key>

# OpenAI model (default: gpt-4o). Change to gpt-4o-mini for cheaper runs.
OPENAI_MODEL=gpt-4o

# Base URL for Auth.js — leave as-is for local dev
NEXTAUTH_URL=http://localhost:3000

# (Optional) GitHub webhook secret — only needed if you enable push webhooks
# GITHUB_WEBHOOK_SECRET=
